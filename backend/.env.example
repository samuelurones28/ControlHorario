# Database
DATABASE_URL="postgresql://control_user:PASSWORD_HERE@localhost:5432/control_horario?schema=public"

# JWT Secrets (min 32 characters, use: openssl rand -hex 32)
JWT_SECRET="GENERATE_WITH_openssl_rand_-hex_32"
JWT_REFRESH_SECRET="GENERATE_WITH_openssl_rand_-hex_32"

# Server
PORT="3000"
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Optional: Audit Log Encryption Key (AES-256, 32 bytes hex)
AUDIT_LOG_KEY="OPTIONAL_GENERATE_WITH_openssl_rand_-hex_32"
