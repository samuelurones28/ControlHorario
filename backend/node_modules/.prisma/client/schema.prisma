generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String           @id @default(uuid())
  code      String           @unique
  name      String
  cif       String           @unique
  address   String?
  createdAt DateTime         @default(now())
  employees Employee[]
  schedules Schedule[]
  holidays  Holiday[]
  absences  AbsenceRequest[]
}

model User {
  id           String     @id @default(uuid())
  email        String?    @unique
  passwordHash String?
  createdAt    DateTime   @default(now())
  employees    Employee[]
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Employee {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id])
  companyId           String
  company             Company              @relation(fields: [companyId], references: [id])
  name                String
  identifier          String
  pinHash             String?
  role                Role                 @default(EMPLOYEE)
  contractType        String?
  weeklyHours         Float                @default(40)
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  timeEntries         TimeEntry[]
  amendmentsApp       TimeEntryAmendment[] @relation("ApprovedAmendments")
  incidents           Incident[]           @relation("EmployeeIncidents")
  incidentsRes        Incident[]           @relation("ResolvedIncidents")
  weeklyReports       WeeklyReport[]
  auditLogs           AuditLog[]
  inviteTokens        InviteToken[]
  privacyConsents     PrivacyConsent[]
  schedules           Schedule[]
  absences            AbsenceRequest[]
  reviewedAbsences    AbsenceRequest[]     @relation("ReviewedAbsences")
  webauthnCredentials WebAuthnCredential[]

  @@unique([userId, companyId])
  @@unique([identifier, companyId])
}

model PrivacyConsent {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  version    String
  acceptedAt DateTime @default(now())
  ipAddress  String
}

model Schedule {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  dayOfWeek  Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime  String // "09:00"
  endTime    String // "17:00"
  isWorkDay  Boolean   @default(true)

  @@unique([employeeId, dayOfWeek])
  @@unique([companyId, dayOfWeek], map: "company_day_unique") // need name for unique constraint or fallback
}

model InviteToken {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

enum EntryType {
  CLOCK_IN
  CLOCK_OUT
  PAUSE_START
  PAUSE_END
}

enum EntrySource {
  REALTIME
  OFFLINE_SYNCED
}

model TimeEntry {
  id         String               @id @default(uuid())
  employeeId String
  employee   Employee             @relation(fields: [employeeId], references: [id])
  entryType  EntryType
  timestamp  DateTime // Stored in UTC
  latitude   Float?
  longitude  Float?
  ipAddress  String?
  deviceInfo String?
  source     EntrySource          @default(REALTIME)
  syncedAt   DateTime?
  metadata   Json?
  createdAt  DateTime             @default(now())
  incidents  Incident[]
  amendments TimeEntryAmendment[]
}

enum IncidentStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Incident {
  id           String               @id @default(uuid())
  employeeId   String
  employee     Employee             @relation("EmployeeIncidents", fields: [employeeId], references: [id])
  timeEntryId  String?
  timeEntry    TimeEntry?           @relation(fields: [timeEntryId], references: [id])
  date         DateTime
  description  String
  status       IncidentStatus       @default(OPEN)
  resolvedById String?
  resolvedBy   Employee?            @relation("ResolvedIncidents", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime             @default(now())
  amendments   TimeEntryAmendment[]
}

enum AmendmentAction {
  ADD
  MODIFY
}

model TimeEntryAmendment {
  id                String          @id @default(uuid())
  incidentId        String?
  incident          Incident?       @relation(fields: [incidentId], references: [id])
  originalEntryId   String?
  originalEntry     TimeEntry?      @relation(fields: [originalEntryId], references: [id])
  employeeId        String
  companyId         String
  action            AmendmentAction
  originalTimestamp DateTime?
  newTimestamp      DateTime
  entryType         EntryType
  reason            String
  createdBy         String
  admin             Employee        @relation("ApprovedAmendments", fields: [createdBy], references: [id])
  createdAt         DateTime        @default(now())
}

enum ReportStatus {
  PENDING_REVIEW
  ACCEPTED
  DISPUTED
}

model WeeklyReport {
  id            String       @id @default(uuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id])
  companyId     String
  weekStart     DateTime
  weekEnd       DateTime
  totalWorked   Float
  totalPaused   Float
  overtime      Float
  data          Json
  status        ReportStatus @default(PENDING_REVIEW)
  disputeReason String?
  reviewedAt    DateTime?
  signature     String?
  createdAt     DateTime     @default(now())
}

model AuditLog {
  id         String    @id @default(uuid())
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  action     String
  entity     String
  entityId   String
  details    Json
  ipAddress  String?
  createdAt  DateTime  @default(now())
}

enum AbsenceType {
  VACATION
  SICK_LEAVE
  PERSONAL
  MATERNITY_PATERNITY
  UNPAID_LEAVE
  OTHER
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Holiday {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime
  name      String
  createdAt DateTime @default(now())

  @@unique([companyId, date])
}

model AbsenceRequest {
  id            String        @id @default(uuid())
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          AbsenceType
  startDate     DateTime
  endDate       DateTime
  businessDays  Int
  notes         String?
  status        AbsenceStatus @default(PENDING)
  reviewedById  String?
  reviewer      Employee?     @relation("ReviewedAbsences", fields: [reviewedById], references: [id])
  reviewNote    String?
  reviewedAt    DateTime?
  attachmentUrl String?
  createdAt     DateTime      @default(now())
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  VIEWER
}

model PlatformAdmin {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  totpSecret   String?
  name         String
  role         PlatformRole         @default(VIEWER)
  active       Boolean              @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  auditLogs    PlatformAuditLog[]
  backupCodes  PlatformBackupCode[]
}

model PlatformBackupCode {
  id              String        @id @default(uuid())
  platformAdminId String
  platformAdmin   PlatformAdmin @relation(fields: [platformAdminId], references: [id])
  codeHash        String
  usedAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([platformAdminId])
}

model PlatformAuditLog {
  id              String        @id @default(uuid())
  platformAdminId String
  platformAdmin   PlatformAdmin @relation(fields: [platformAdminId], references: [id])
  action          String
  entity          String?
  entityId        String?
  details         Json?
  ipAddress       String
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([platformAdminId])
  @@index([createdAt])
  @@index([action])
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model NationalHoliday {
  id        String   @id @default(uuid())
  date      DateTime
  name      String
  region    String   @default("ES")
  createdAt DateTime @default(now())

  @@unique([date, region])
}

model WebAuthnCredential {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  credentialId String    @unique // Base64 encoded
  publicKey    String // Base64 encoded
  counter      Int       @default(0) // For replay attack prevention
  transports   String[] // Array of transport types (e.g., ["usb", "nfc", "ble"])
  aaguid       String? // Authenticator AAGUID
  name         String? // User-friendly name (e.g., "iPhone", "Windows Hello")
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([employeeId])
}
